{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "g++",
            "args": [
                "-g",
                "skeleton_projection.cpp",
                "-o",
                "skeleton_projection.exe",
                "-lGL",
                "-lGLFW",
                "-lGLU",
                "-lm"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "detail": "Generated task by VS Code"
        },
        {
            "label": "run",
            "type": "shell",
            "command": "./skeleton_projection.exe",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "dependsOn": "build"
        }
    ]
}
